# Claude API (text generation)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# OpenAI API (image generation via DALL-E 3)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Make webhook URL (LinkedIn automation)
VITE_MAKE_WEBHOOK_URL=https://hook.eu2.make.com/YOUR_WEBHOOK_HERE

# Auth credentials — format: email:password
# Each variable maps to a profile ID (michal / petr / pavel / karel)
AUTH_michal=michal@example.com:heslo123
AUTH_petr=petr@example.com:heslo123
AUTH_pavel=pavel@example.com:heslo123
AUTH_karel=karel@example.com:heslo123
AUTH_jiri=jiri.vyslouzil@micostelcom.cz:heslo123

# Firebase (Firestore archive)
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
